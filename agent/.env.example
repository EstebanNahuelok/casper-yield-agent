# Groq
GROQ_API_KEY=your_groq_api_key_here

# Casper MCP Server (local, levantado con casper-mcp CLI)
CASPER_MCP_URL=http://localhost:3001/mcp
CSPR_CLOUD_API_KEY=your_cspr_cloud_api_key_here

# CSPR.trade MCP (remoto)
CSPRTRADE_MCP_URL=https://mcp.cspr.trade/mcp

# Wallet del vault
VAULT_PUBLIC_KEY=your_casper_public_key_here
VAULT_SECRET_KEY=your_casper_secret_key_here

# Contrato YieldVault (hash del deploy de Persona 1)
VAULT_CONTRACT_HASH=hash-abc123...
SCSPR_CONTRACT_HASH=hash-scspr...

# Red
CASPER_NETWORK=testnet

# Comportamiento del agente
CHECK_INTERVAL_SECONDS=300
MIN_APY_DELTA=2.0
MAX_SLIPPAGE_PCT=1.5
MIN_BALANCE_CSPR=100.0

# API del agente (para el frontend)
API_HOST=0.0.0.0
API_PORT=8000
