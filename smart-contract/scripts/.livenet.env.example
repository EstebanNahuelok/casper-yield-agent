# Copy to .livenet.env and fill in your values.
# This file is loaded automatically by deposit.sh and deploy.sh.

CSPR_CLOUD_AUTH_TOKEN=your_token_here
ODRA_CASPER_LIVENET_SECRET_KEY_PATH=/path/to/secret_key.pem

# Optional overrides (defaults shown):
# ODRA_CASPER_LIVENET_NODE_ADDRESS=http://127.0.0.1:7777/rpc
# ODRA_CASPER_LIVENET_EVENTS_URL=http://127.0.0.1:9999/events/main
# ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test
